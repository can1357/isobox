# Formatting for the isoboxfs C preload (preload/isoboxfs).
# Apply with `just fmt-c`; CI fails if sources are not formatted.
---
Language: Cpp
BasedOnStyle: LLVM
IndentWidth: 4
ColumnLimit: 100
# The sources keep one statement per line rather than collapsing short bodies.
AllowShortFunctionsOnASingleLine: None
AlignEscapedNewlines: Left
